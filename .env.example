# App
APP_NAME=onyxcode-fscu-api
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# API public controls
API_PREFIX=/v1
API_MAX_CONCURRENT_REQUESTS=20
API_REQUEST_TIMEOUT_SECONDS=5

# Rate limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_IP=20
RATE_LIMIT_PER_RUT=5
RATE_LIMIT_BURST=5
RATE_LIMIT_WINDOW_SECONDS=60

# UTM conversion
UTM_API_URL=https://api.boostr.cl/economy/indicator/utm.json
UTM_CACHE_TTL_SECONDS=86400
UTM_REQUEST_TIMEOUT_SECONDS=5

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=onyxcode_fscu
POSTGRES_USER=onyxcode_ro
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://onyxcode_ro:change-me@postgres:5432/onyxcode_fscu

# Security / timeouts
DB_STATEMENT_TIMEOUT_MS=3000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=5000
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=5
